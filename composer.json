{
    "name": "dwebserver/laravel-sanity-check",
    "description": "Laravel admin dashboard and Artisan command to scan routes, resolve parameters, execute HTTP checks, classify responses, and optionally persist results with JSON/CSV export.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "sanity-check",
        "health-check",
        "routes",
        "admin",
        "monitoring",
        "http",
        "dashboard",
        "artisan",
        "testing"
    ],
    "homepage": "https://github.com/dwebserver/laravel-sanity-check",
    "support": {
        "issues": "https://github.com/dwebserver/laravel-sanity-check/issues",
        "source": "https://github.com/dwebserver/laravel-sanity-check",
        "docs": "https://github.com/dwebserver/laravel-sanity-check#readme"
    },
    "authors": [
        {
            "name": "Dynamicweb",
            "email": "info@dwebserver.net",
            "homepage": "https://github.com/dwebserver",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/view": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "~1.13.0",
        "nunomaduro/collision": "^7.0|^8.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "DynamicWeb\\SanityCheck\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DynamicWeb\\SanityCheck\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DynamicWeb\\SanityCheck\\SanityCheckServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "lint": "pint --test",
        "format": "pint",
        "analyse": "phpstan analyse --memory-limit=512M",
        "test": "phpunit",
        "test:ci": "phpunit --log-junit build/logs/junit.xml",
        "test-coverage": "phpunit --coverage-html build/coverage",
        "test:coverage-ci": "phpunit --coverage-clover build/logs/clover.xml"
    }
}
